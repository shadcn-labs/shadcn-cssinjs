{
  "name": "shadcn-cssinjs-monorepo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "dev": "turbo run dev --filter=www",
    "fix": "pnpm --filter=www fix",
    "prepare": "lefthook install",
    "registry:build": "pnpm --filter=www registry:build",
    "typecheck": "turbo run typecheck",
    "www:build": "pnpm --filter=www build",
    "www:dev": "pnpm --filter=www dev"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "lefthook": "^2.1.6",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "ultracite": "7.6.1"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "brace-expansion": "5.0.7",
      "esbuild": "0.28.1",
      "fast-uri": "3.1.3",
      "hono": "4.12.29",
      "ip-address": "10.1.1",
      "js-yaml": "4.3.0",
      "postcss": "8.5.10",
      "qs": "6.15.3"
    }
  }
}
