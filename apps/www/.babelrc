{
  "presets": ["next/babel", "@babel/preset-typescript"],
  "plugins": [
    [
      "@stylexjs/babel-plugin",
      {
        "runtimeInjection": false,
        "styleResolution": "property-specificity",
        "aliases": {
          "@/registry/bases/stylex/lib/*": ["../lib/*"]
        },
        "unstable_moduleResolution": {
          "type": "commonJS",
          "rootDir": "."
        }
      }
    ]
  ]
}
